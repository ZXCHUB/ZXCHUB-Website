rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == 'zxchubadmin@gmail.com')
      );
    }

    function isModerator() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'moderator'
      );
    }

    function isEditableScript(data) {
      return data.type == 'script' || data.slug != 'zxchub-key';
    }
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
      ));
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() || (
        isModerator() &&
        request.resource.data.type == 'script' &&
        request.resource.data.slug != 'zxchub-key'
      );
      allow delete: if isAdmin() || (isModerator() && isEditableScript(resource.data));
      allow update: if isAdmin() || (
        isModerator() &&
        isEditableScript(resource.data) &&
        request.resource.data.type == 'script' &&
        request.resource.data.slug != 'zxchub-key'
      ) || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])
      ) || (
        isAuthenticated() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'dislikes', 'commentsCount', 'views'])
      );

      match /viewers/{sessionId} {
        allow read, write: if true;
      }

      match /likes/{userId} {
        allow read: if true;
        allow create, delete: if isAuthenticated() && request.auth.uid == userId;
      }

      match /dislikes/{userId} {
        allow read: if true;
        allow create, delete: if isAuthenticated() && request.auth.uid == userId;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow update: if isAdmin() || isModerator() || (isAuthenticated() && (
          resource.data.userId == request.auth.uid ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'dislikes', 'repliesCount'])
        ));
        allow delete: if isAdmin() || isModerator() || (isAuthenticated() && resource.data.userId == request.auth.uid);

        match /reactions/{userId} {
          allow read: if true;
          allow create, update, delete: if isAuthenticated() && request.auth.uid == userId;
        }

        match /replies/{replyId} {
          allow read: if true;
          allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
          allow update: if isAdmin() || isModerator() || (isAuthenticated() && (
            resource.data.userId == request.auth.uid ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'dislikes'])
          ));
          allow delete: if isAdmin() || isModerator() || (isAuthenticated() && resource.data.userId == request.auth.uid);

          match /reactions/{userId} {
            allow read: if true;
            allow create, update, delete: if isAuthenticated() && request.auth.uid == userId;
          }
        }
      }
    }

    match /keys/{keyId} {
      allow read: if isAdmin() || isModerator() || (isAuthenticated() && resource.data.ownerId == request.auth.uid) || resource.data.isSold == false;
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        isAuthenticated() && 
        resource.data.isSold == false && 
        request.resource.data.isSold == true && 
        request.resource.data.ownerId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    match /transactions/{txId} {
      allow read: if isAdmin() || isModerator() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /tickets/{ticketId} {
      allow read: if isAdmin() || isModerator() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || isModerator() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin() || isModerator();
      
      match /messages/{messageId} {
         allow read: if isAdmin() || isModerator() || (isAuthenticated() && get(/databases/$(database)/documents/tickets/$(ticketId)).data.userId == request.auth.uid);
         allow create: if isAdmin() || isModerator() || (isAuthenticated() && (
            (exists(/databases/$(database)/documents/tickets/$(ticketId)) && get(/databases/$(database)/documents/tickets/$(ticketId)).data.userId == request.auth.uid) ||
            request.resource.data.ticketUserId == request.auth.uid
         ));
         allow update, delete: if isAdmin() || isModerator();
      }
    }

    match /pageviews/{docId} {
      allow read: if isAdmin() || isModerator();
      allow create: if true;
    }
    match /auditLogs/{logId} {
      allow read: if isAdmin() || isModerator();
      allow create: if isAdmin() || isModerator();
      allow update, delete: if false;
    }
    match /polls/{pollId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isAuthenticated() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['voteCounts', 'totalVotes', 'lastVoteAt']) &&
        request.resource.data.totalVotes == resource.data.totalVotes + 1
      );

      match /votes/{userId} {
        allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
        allow create: if isAuthenticated() &&
          request.auth.uid == userId &&
          request.resource.data.userId == request.auth.uid &&
          !exists(/databases/$(database)/documents/polls/$(pollId)/votes/$(userId)) &&
          get(/databases/$(database)/documents/polls/$(pollId)).data.status == 'active' &&
          get(/databases/$(database)/documents/polls/$(pollId)).data.endsAt > request.time.toMillis();
        allow update, delete: if false;
      }
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
